# AI Network Operations Platform — environment contract (M0)
# Copy to .env and adjust. Every variable maps 1:1 to a field in
# backend/app/core/config.py (pydantic-settings, prefix NETOPS_).
# Hostnames default to docker compose service names (deploy/docker/docker-compose.yml).

# Deployment environment: dev | prod.
# In prod the platform refuses to start with the default secret key below.
NETOPS_ENV=dev

# HS256 signing key for JWT access tokens. Generate a strong value for any
# shared or production deployment, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(64))"
NETOPS_SECRET_KEY=dev-only-insecure-secret-key-change-me

# Bootstrap 'admin' account password. EXCEPTION to the 1:1-with-config.py rule
# above: this is read directly from the environment by the M1 Alembic migration
# (backend/alembic/versions/0001_*) the first time `alembic upgrade head` seeds the admin
# user — it is NOT a config.py field. If unset, the migration seeds the insecure
# default "admin" and logs a loud warning. Set a strong value before the first
# migration and rotate after first login.
NETOPS_ADMIN_PASSWORD=pwCHANGEME

# PostgreSQL system of record (async SQLAlchemy DSN, asyncpg driver).
NETOPS_DATABASE_URL=postgresql+asyncpg://netops:netops@postgres:5432/netops

# Redis — Celery broker/result backend and cache.
NETOPS_REDIS_URL=redis://redis:6379/0

# Neo4j topology / knowledge graph.
NETOPS_NEO4J_URI=bolt://neo4j:7687
NETOPS_NEO4J_USER=neo4j
NETOPS_NEO4J_PASSWORD=pwCHANGEME

# LLM provider profile: local (Ollama, default) | anthropic | openai | azure.
# Local-first: no traffic leaves the deployment unless you opt into a cloud profile.
NETOPS_LLM_PROFILE=local

# Ollama endpoint (compose service "ollama", started with --profile local-llm).
NETOPS_OLLAMA_BASE_URL=http://ollama:11434

# Allowed browser origins as a JSON list. Keep the JSON quoting intact: it is
# parsed by pydantic-settings as JSON. Compose `env_file:` / `--env-file` and
# `uvicorn --env-file` read this file verbatim and preserve the quotes; do NOT
# hand-export it by sourcing this file in a plain shell (`set -a; . .env`), which
# strips the inner double-quotes and makes pydantic raise a parse error.
NETOPS_CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]

# JWT access-token lifetime in minutes.
NETOPS_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---------------------------------------------------------------------------
# pgBackRest backup tier — Compose host-cron parity ONLY (W5-T1, ADR-0030 §1/§4).
# These are NOT app config (no NETOPS_ prefix, not in config.py) — they are read
# by docker-compose.backup.yml (`--profile backup`). The chart sources the same
# values from the platform Secret / external-secrets, never from here.
# ---------------------------------------------------------------------------
# aes-256-cbc repo passphrase — REQUIRED when the backup profile is up; generate
# a strong value, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# This is the repo cipher pass — a DISTINCT secret from any KEK; never co-locate
# it with the repo (ADR-0011 §4).
PGBACKREST_REPO1_CIPHER_PASS=pwCHANGEME
# Dev MinIO root credential = the object-store key/secret the backup writes with.
MINIO_ROOT_USER=netops-backup
MINIO_ROOT_PASSWORD=pwCHANGEME
