{
  "uid": "netops-llm",
  "title": "NetOps — LLM providers golden signals",
  "netopsSubject": "llm",
  "description": "Golden-signal dashboard for the LLM providers (ADR-0046 §4, §335). Built on the netops_llm_* base series (ADR-0009 / ADR-0015 §2): latency p95 + requests/s + token throughput per ADR-0009 profile. FLAGGED: no LLM error-rate series exists yet (the request counter has no outcome label) — the errors panel uses the latency tail as the degradation proxy and the gap is named-deferred to the LLM-metrics owner (needed for the W3-T5 LLM-provider-failure MTTD on an error ratio).",
  "tags": [
    "netops",
    "golden-signals",
    "slo",
    "llm"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus",
        "hide": 0,
        "current": {},
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Latency — request latency p95 by profile",
      "netopsGoldenSignal": "latency",
      "description": "histogram_quantile over netops_llm_latency_seconds_bucket by profile (ADR-0015 §2). The agent first-token p95 SLO (§6 row 3) has its own recording rule on the api dashboard / agent alert.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "showLegend": true
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "histogram_quantile(0.95, sum by (le, profile) (rate(netops_llm_latency_seconds_bucket[5m])))",
          "legendFormat": "{{profile}} p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Traffic — LLM requests/s by profile",
      "netopsGoldenSignal": "traffic",
      "description": "",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "showLegend": true
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (profile) (rate(netops_llm_requests_total[5m]))",
          "legendFormat": "{{profile}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Errors — provider availability (FLAGGED: no error-rate series yet)",
      "netopsGoldenSignal": "errors",
      "description": "FLAGGED: netops_llm_requests_total carries {profile, model} only — no outcome/status label and no netops_llm_errors_total exists today, so a true LLM error-RATE cannot be plotted. The available degradation signal is the latency tail (left panel) crossing the profile SLO. Named-deferred to the LLM-metrics owner: add an `outcome` label to netops_llm_requests_total (or a netops_llm_errors_total{profile,model}) so the W3-T5 LLM-provider-failure fault-injection alerts on an error ratio, not just latency.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "showLegend": true
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "histogram_quantile(0.95, sum by (le, profile) (rate(netops_llm_latency_seconds_bucket[5m])))",
          "legendFormat": "{{profile}} p95 (degradation proxy)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Saturation — token throughput by direction (cost/load)",
      "netopsGoldenSignal": "saturation",
      "description": "rate(netops_llm_tokens_total) by direction — token throughput is the LLM load/cost saturation signal (ADR-0009 D3; local GPU vs external rate cap).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "showLegend": true
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (direction) (rate(netops_llm_tokens_total[5m]))",
          "legendFormat": "{{direction}} tokens/s",
          "refId": "A"
        }
      ]
    }
  ],
  "netopsProvenance": {
    "task": "W3-T4",
    "adr": "ADR-0046 §4",
    "production": "PRODUCTION.md §6 / §11 G-OBS §335"
  }
}
