# SpatiumDDI lab stack — example env (copy to `.env`; NEVER commit the real .env).
#
# These configure the LAB SpatiumDDI appliance (deploy/spatiumddi/docker-compose.yml).
# They are NOT the env vars the live test reads — those (SPATIUMDDI_BASE_URL /
# SPATIUMDDI_TOKEN / SPATIUMDDI_GROUP_ID / SPATIUMDDI_ZONE_ID) are exported in your
# shell AFTER you mint a token. See README.md.
#
# All secrets below are LAB placeholders. Replace them; do not reuse real creds.

# Pin a known SpatiumDDI image tag (do NOT float :latest for a reproducible lab).
# Replace the placeholder below with the latest stable release tag from
# https://github.com/spatiumddi/spatiumddi/releases (e.g. v1.2.3).
SPATIUMDDI_IMAGE=ghcr.io/spatiumddi/spatiumddi:v0.1.0

# Bootstrap admin used ONCE to log in and mint the resource-scoped API token.
SPATIUMDDI_ADMIN_EMAIL=admin@spatiumddi.lab
SPATIUMDDI_ADMIN_PASSWORD=change-me-lab-admin-password

# Lab Postgres credentials for the SpatiumDDI database (passed as discrete env
# vars — NOT spliced into a URI, so any character is safe in the password).
SPATIUMDDI_DB_USER=spatium
SPATIUMDDI_DB_PASSWORD=change-me-lab-db-password
SPATIUMDDI_DB_NAME=spatiumddi
