# SpatiumDDI lab stack — example env (copy to `.env`; NEVER commit the real .env).
#
# These configure the LAB SpatiumDDI appliance (deploy/spatiumddi/docker-compose.yml).
# They match the UPSTREAM SpatiumDDI compose contract. They are NOT the vars the
# live test reads — those (SPATIUMDDI_BASE_URL / SPATIUMDDI_TOKEN /
# SPATIUMDDI_GROUP_ID / SPATIUMDDI_ZONE_ID) are exported in your shell AFTER you
# mint a token (see README.md).
#
# All secrets below are LAB placeholders. Replace them; do not reuse real creds.

# Postgres password for the SpatiumDDI database. The compose builds
# DATABASE_URL=postgresql+asyncpg://spatiumddi:<this>@postgres:5432/spatiumddi.
POSTGRES_PASSWORD=change-me-lab-db-password

# App secret key — used to derive at-rest encryption. Generate with:
#   openssl rand -hex 32
SECRET_KEY=change-me-openssl-rand-hex-32

# Only needed if you also run the opt-in bind9 / kea agent profiles (not required
# for the DNS-record golden path). Generate with: openssl rand -hex 32
DNS_AGENT_KEY=

# Host port the API publishes (bound to 127.0.0.1 by the compose). The live test
# then uses SPATIUMDDI_BASE_URL=http://127.0.0.1:<API_PORT>.
API_PORT=8000

# Pin a real published image tag for a reproducible lab. Tags are CalVer, e.g.
# 2026.06.19-1 (see https://github.com/spatiumddi/spatiumddi/releases). `latest`
# also resolves. Image: ghcr.io/spatiumddi/spatiumddi-api:<this>.
SPATIUMDDI_VERSION=latest
